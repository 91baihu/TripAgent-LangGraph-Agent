# TripAgent 生产环境配置
# ⚠️ 此文件仅作模板参考，生产密钥请通过 Secret Manager / K8s Secrets 注入

APP_ENV=prod
LOG_LEVEL=WARNING

# 数据库 (使用 Secret Manager，此处仅占位)
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=tripagent
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# 服务端口
API_PORT=8000
NGINX_PORT=80

# JWT (使用 Secret Manager)
JWT_SECRET_KEY=${JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# 限流 (生产环境严格)
RATE_LIMIT_FREE_PER_DAY=3
RATE_LIMIT_PRO_PER_DAY=100
RATE_LIMIT_IP_PER_MINUTE=30

# Token 预算 (生产环境严格控制)
TOKEN_BUDGET_MAX_PER_REQUEST=20000
TOKEN_COST_ALERT_PER_DAY=50
