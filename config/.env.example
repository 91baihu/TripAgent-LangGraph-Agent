# TripAgent 环境变量模板
# 复制此文件为 dev.env / staging.env / prod.env 并填入真实值

# ========== 运行环境 ==========
APP_ENV=dev           # dev | staging | prod
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR

# ========== LLM 配置 ==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# 备用模型（可选）
# GLM_API_KEY=
# QWEN_API_KEY=

# ========== 数据库 ==========
POSTGRES_USER=tripagent
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tripagent
POSTGRES_PORT=5432

# ========== Redis ==========
REDIS_PORT=6379

# ========== 服务端口 ==========
API_PORT=8000
ADMIN_PORT=8501
NGINX_PORT=80

# ========== JWT 鉴权 ==========
JWT_SECRET_KEY=change_me_to_random_64_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 第三方 API ==========
# 高德地图 (景点搜索 + 路线规划)
AMAP_API_KEY=
# 和风天气 (天气预报)
HEFENG_API_KEY=
# 携程开放平台 (酒店)
CTRIP_API_KEY=
CTRIP_API_SECRET=

# ========== 限流 ==========
RATE_LIMIT_FREE_PER_DAY=3
RATE_LIMIT_PRO_PER_DAY=100
RATE_LIMIT_IP_PER_MINUTE=30

# ========== Token 成本控制 ==========
TOKEN_BUDGET_MAX_PER_REQUEST=20000
TOKEN_COST_ALERT_PER_DAY=50
